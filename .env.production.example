APP_NAME="GlobalAfrica+"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://globalafricaplus.com
APP_TIMEZONE=UTC
APP_LOCALE=fr

LOG_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=globalafricaplus
DB_USERNAME=gapuser
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@globalafricaplus.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=no-reply@globalafricaplus.com
MAIL_FROM_NAME="GlobalAfrica+"

# IDNorm KYC (mode prod)
IDNORM_MODE=prod
IDNORM_BASE_URL=https://api.idnorm.com/v1
IDNORM_API_KEY=
IDNORM_API_SECRET=
IDNORM_WEBHOOK_SECRET=

# Sanctum / Session
SANCTUM_STATEFUL_DOMAINS=globalafricaplus.com,www.globalafricaplus.com
SESSION_DOMAIN=.globalafricaplus.com
SESSION_SECURE_COOKIE=true
